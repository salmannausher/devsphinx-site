    const upd=()=>{
      const h=document.documentElement;
      const max=h.scrollHeight-window.innerHeight;
      spb.style.transform='scaleX('+(max>0?Math.min(window.scrollY/max,1):0)+')';
    };
    window.addEventListener('scroll',upd,{passive:true});
    window.addEventListener('resize',upd,{passive:true});
    upd();
  }

  if(RM)return;

  /* Split-text word reveals */
  function split(el){
    const walk=node=>{
      [...node.childNodes].forEach(ch=>{
        if(ch.nodeType===3&&ch.textContent.trim()){
          const frag=document.createDocumentFragment();
          ch.textContent.split(/(\s+)/).forEach(tok=>{
            if(!tok)return;
            if(/^\s+$/.test(tok)){frag.appendChild(document.createTextNode(' '));return;}
            const w=document.createElement('span');w.className='sw';
            const i=document.createElement('i');i.textContent=tok;
            w.appendChild(i);frag.appendChild(w);
          });
          node.replaceChild(frag,ch);
        }else if(ch.nodeType===1&&ch.tagName!=='BR'){walk(ch);}
      });
    };
    walk(el);
    el.querySelectorAll('.sw i').forEach((w,i)=>w.style.setProperty('--d',(i*.05)+'s'));
  }
  document.querySelectorAll('[data-split]').forEach(split);

  /* Hero entrance on load */
  const heroH1=document.querySelector('.hero-h1');
  const heroSec=document.getElementById('hero');
  requestAnimationFrame(()=>requestAnimationFrame(()=>{
    if(heroH1)heroH1.classList.add('split-vis');
    if(heroSec)heroSec.classList.add('hero-in');
  }));

  /* Scroll-triggered heading reveals */
  const sObs=new IntersectionObserver(es=>es.forEach(x=>{
    if(x.isIntersecting){x.target.classList.add('split-vis');sObs.unobserve(x.target);}
  }),{threshold:.3});
  document.querySelectorAll('[data-split]:not(.hero-h1)').forEach(el=>sObs.observe(el));

  /* Grid cascade stagger */
  const gObs=new IntersectionObserver(es=>es.forEach(x=>{
    if(x.isIntersecting){[...x.target.children].forEach(c=>c.classList.add('vis'));gObs.unobserve(x.target);}
  }),{threshold:.08});
  document.querySelectorAll('.srv-grid,.why-grid,.ind-grid,.eng-grid,.mf-grid,.fit-grid,.work-grid').forEach(g=>{
    const host=g.classList.contains('fu')?g:g.closest('.fu');
    if(host){host.classList.remove('fu','fd1','fd2','fd3');host.classList.add('vis');}
    [...g.children].forEach((c,i)=>{c.classList.add('st-child');c.style.transitionDelay=(i*.06)+'s';});
    gObs.observe(g);
  });

  /* Animated counters */
  const ease=t=>1-Math.pow(2,-10*t);
  function runCount(el){
    const target=parseFloat(el.dataset.count)||0,dur=1300,t0=performance.now();
    const step=now=>{
      const p=Math.min((now-t0)/dur,1);
      el.textContent=Math.round(target*ease(p));
      if(p<1)requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }
  const cObs=new IntersectionObserver(es=>es.forEach(x=>{
    if(x.isIntersecting){runCount(x.target);cObs.unobserve(x.target);}
  }),{threshold:.6});
  document.querySelectorAll('.cnt[data-count]').forEach(el=>cObs.observe(el));

  /* Card spotlight + magnetic CTAs (pointer devices only) */
  if(window.matchMedia('(hover:hover)').matches){
    document.querySelectorAll('.srv-card,.why-card,.eng-card,.ind-card,.mf-card,.fit-card,.wk-card').forEach(card=>{
      card.addEventListener('mousemove',e=>{
        const r=card.getBoundingClientRect();
        card.style.setProperty('--mx',(e.clientX-r.left)+'px');
        card.style.setProperty('--my',(e.clientY-r.top)+'px');
      });
    });
    document.querySelectorAll('.btn-ac').forEach(b=>{
      b.style.transition='transform .18s cubic-bezier(.22,1,.36,1),opacity .15s';
      b.addEventListener('mousemove',e=>{
        const r=b.getBoundingClientRect();
        b.style.transform='translate('+((e.clientX-r.left-r.width/2)*.18)+'px,'+((e.clientY-r.top-r.height/2)*.32)+'px)';
      });
      b.addEventListener('mouseleave',()=>{b.style.transform='';});
    });
  }
})();

/* Nav highlight */
const secs=document.querySelectorAll('section[id],div[id]');
const nls=document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{let cur='';secs.forEach(s=>{if(window.scrollY>=s.offsetTop-100)cur=s.id;});nls.forEach(a=>{a.style.color=new URL(a.href).hash==='#'+cur?'var(--t)':'';});},{passive:true});

/* Agent flow pulse — sweeps through the pipeline, respects reduced motion */
(function(){
  const track=document.getElementById('flowTrack');
  if(!track)return;
  const boxes=[...track.querySelectorAll('[data-step]')];
  const arrows=[...track.querySelectorAll('[data-arr]')];
  let step=0;
  function render(){
    boxes.forEach(b=>b.classList.toggle('active',Number(b.dataset.step)===step));
    arrows.forEach(a=>a.classList.toggle('active',Number(a.dataset.arr)===step));
  }
  render();
  if(window.matchMedia('(prefers-reduced-motion: reduce)').matches)return;
  function tick(){
    setTimeout(()=>{step=step>=5?0:step+1;render();tick();},step===5?1500:850);
  }
  tick();
})();
</script>
</BaseLayout>
