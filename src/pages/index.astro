---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home.css';

const title = "Devsphinx — AI-First Software Studio";
const description = "Devsphinx builds AI agent systems and AI-first software that replace manual workflows in weeks. Fixed-scope builds, production architecture, and Claude-native delivery.";

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Do you only build AI agents, or do you build full software products too?", "acceptedAnswer": { "@type": "Answer", "text": "Both. We build autonomous AI agent systems (multi-agent pipelines for sales, ops, and support) and full AI-first software products (SaaS platforms, internal tools, vertical apps). AI is the core architecture in everything we build, not a feature bolted on afterward." } },
    { "@type": "Question", "name": "What's the difference between AI-first software and just adding AI to an app?", "acceptedAnswer": { "@type": "Answer", "text": "AI-first means the AI layer is designed before anything else — what the model handles, what data it needs, how it interacts with the rest of the system. The result is software where AI handles the heavy lifting on every core workflow, not just one bolt-on feature." } },
    { "@type": "Question", "name": "How is this different from Zapier, Make, or a chatbot?", "acceptedAnswer": { "@type": "Answer", "text": "Automation tools move data between apps without reasoning or deciding anything. Devsphinx builds agent systems that research context, evaluate options, and take action autonomously — the difference between an automation rule and an employee who uses judgment." } },
    { "@type": "Question", "name": "How long does a typical project take?", "acceptedAnswer": { "@type": "Answer", "text": "Agent systems: 3–5 weeks in production. AI-first software products: 4–8 weeks for an MVP, depending on scope." } },
    { "@type": "Question", "name": "What does it cost?", "acceptedAnswer": { "@type": "Answer", "text": "Agent system builds start from $8,000, typically $10,000–$15,000 complete. AI-first software MVPs start from $12,000. All engagements are fixed-price. Monthly retainers for ongoing evolution start at $2,500/month." } },
    { "@type": "Question", "name": "Do you work with early-stage startups?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — some of our best-fit engagements are early-stage products where the founding team wants to build AI-first from the start rather than retrofit later." } },
    { "@type": "Question", "name": "Do you sign NDAs?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We sign a mutual NDA before the discovery call on request. Most case studies are anonymised for this reason." } },
    { "@type": "Question", "name": "What happens if you're at capacity, or I need support after launch?", "acceptedAnswer": { "@type": "Answer", "text": "We only take on a small number of builds at a time, so if we can't meet your timeline, we'll tell you honestly on the discovery call and point you to someone we trust rather than overcommit. Every build ships with documentation and a 2-week hypercare window. Ongoing support runs on a monthly retainer with response expectations agreed upfront." } }
  ]
};
---

<BaseLayout title={title} description={description}>
<link slot="head" href="https://fonts.googleapis.com/css2?family=Caveat:wght@600;700&display=swap" rel="stylesheet" />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<div id="scroll-progress" aria-hidden="true"><span></span></div>

<!-- NAV -->
<nav>
  <a href="/#hero" class="nav-logo">Dev<em>sphinx</em></a>
  <ul class="nav-links">
    <li><a href="/#services">Services</a></li>
    <li><a href="/#process">Process</a></li>
    <li><a href="/#industries">Industries</a></li>
    <li><a href="/#work">Work</a></li>
    <li><a href="/blog/">Blog</a></li>
    <li><a href="/#founder">Founder</a></li>
    <li><a href="/#faq">FAQ</a></li>
  </ul>
  <a href="/#booking" class="btn btn-ac btn-sm nav-cta">Book a discovery call</a>
  <button class="ham" id="ham-btn" aria-label="Menu" aria-expanded="false" aria-controls="mob-menu" onclick="toggleMob()">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mob-menu" id="mob-menu" aria-hidden="true">
  <a href="/#services" onclick="closeMob()">Services</a>
  <a href="/#process" onclick="closeMob()">Process</a>
  <a href="/#industries" onclick="closeMob()">Industries</a>
  <a href="/#work" onclick="closeMob()">Work</a>
  <a href="/blog/" onclick="closeMob()">Blog</a>
  <a href="/#founder" onclick="closeMob()">Founder</a>
  <a href="/#faq" onclick="closeMob()">FAQ</a>
  <a href="/#booking" class="btn btn-ac" onclick="closeMob()">Book a discovery call →</a>
</div>

<!-- HERO -->
<section id="hero">
  <div class="hero-inner">
    <div class="hero-pill hero-el" style="--hd:.05s;">
      <div class="pill-dot"></div>
      AI-First Software Studio &nbsp;·&nbsp; Devsphinx
    </div>
    <h1 class="hero-h1" data-split>Replace manual workflows<br><span class="hl">with AI-first systems.</span></h1>
    <p class="hero-sub hero-el" style="--hd:.5s;">We build AI agent systems and AI-first software that automate sales, ops, support, and internal workflows — shipped as fixed-scope production builds in weeks.</p>
    <div class="hero-distinction hero-el" style="--hd:.65s;">
      <span class="hd-item active">AI Agent Systems</span>
      <div class="hd-sep"></div>
      <span class="hd-item active">AI-First Products</span>
      <div class="hd-sep"></div>
      <span class="hd-item active">Claude-Native</span>
      <div class="hd-sep"></div>
      <span class="hd-item active">3–5 Week Delivery</span>
    </div>
    <div class="hero-btns hero-el" style="--hd:.8s;">
      <a href="/#booking" class="btn btn-ac">Book a free discovery call &nbsp;→</a>
      <a href="/#services" class="btn btn-ghost">See what we build</a>
    </div>
    <div class="hero-proof hero-el" style="--hd:.95s;" aria-label="Delivery proof points">
      <span class="proof-chip"><strong>Fixed-price</strong> builds</span>
      <span class="proof-chip"><strong>Claude</strong> native</span>
      <span class="proof-chip"><strong>MCP</strong> integrations</span>
      <span class="proof-chip"><strong>Production</strong> architecture</span>
      <span class="proof-chip"><strong>Founder-led</strong> delivery</span>
    </div>
  </div>
  <div class="scroll-hint">
    <div class="scroll-bar"></div>
    <span>Scroll</span>
  </div>
</section>

<!-- STATS -->
<div id="stats">
  <div class="stats-grid">
    <div class="stat-cell fu"><div class="stat-num"><span class="cnt" data-count="3">3</span><span>–5</span></div><div class="stat-lbl">Weeks to production</div></div>
    <div class="stat-cell fu fd1"><div class="stat-num"><span class="cnt" data-count="2">2</span><span>×</span></div><div class="stat-lbl">Delivery modes</div></div>
    <div class="stat-cell fu fd2"><div class="stat-num"><span class="cnt" data-count="5">5</span><span>+</span></div><div class="stat-lbl">Industries served</div></div>
    <div class="stat-cell fu fd3"><div class="stat-num"><span class="cnt" data-count="0">0</span><span>%</span></div><div class="stat-lbl">Hourly billing. Ever.</div></div>
  </div>
</div>

<!-- APPROACH SPLIT -->
<div id="approach">
  <div class="app-inner fu">
    <div class="app-side">
      <span class="eyebrow eyebrow-ac" style="margin-bottom:12px;display:block;">AI Agent Systems</span>
      <h3>Autonomous agents that run your business operations</h3>
      <p>Multi-agent pipelines built on Claude that handle sales outreach, operations workflows, customer support, and internal processes — 24/7, without human input. Not chatbots. Not automations. AI that thinks and acts.</p>
    </div>
    <div class="app-divider"></div>
    <div class="app-side">
      <span class="eyebrow" style="color:var(--blue);margin-bottom:12px;display:block;">AI-First Software</span>
      <h3>Software where AI is the architecture, not an add-on</h3>
      <p>Web apps, SaaS platforms, and custom software built with AI at the core — not bolted on after launch. Every design decision starts with "what should AI handle here?" The result is software that gets smarter as it's used.</p>
    </div>
  </div>
</div>

<!-- AGENT FLOW -->
<div id="agent-flow">
  <div class="af-inner">
    <div class="af-label fu">Example pipeline · AI Revenue Engine</div>
    <div class="flow-track fu fd1" id="flowTrack">
      <div class="flow-node"><div class="fn-box" data-step="0"><div class="fn-role">Agent 01</div><div class="fn-name">Research</div></div></div>
      <div class="flow-arr" data-arr="1"><svg viewBox="0 0 18 18" fill="none"><path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
      <div class="flow-node"><div class="fn-box" data-step="1"><div class="fn-role">Agent 02</div><div class="fn-name">Personalise</div></div></div>
      <div class="flow-arr" data-arr="2"><svg viewBox="0 0 18 18" fill="none"><path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
      <div class="flow-node"><div class="fn-box" data-step="2"><div class="fn-role">Agent 03</div><div class="fn-name">Outreach</div></div></div>
      <div class="flow-arr" data-arr="3"><svg viewBox="0 0 18 18" fill="none"><path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
      <div class="flow-node"><div class="fn-box" data-step="3"><div class="fn-role">Agent 04</div><div class="fn-name">CRM Sync</div></div></div>
      <div class="flow-arr" data-arr="4"><svg viewBox="0 0 18 18" fill="none"><path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
      <div class="flow-node"><div class="fn-box" data-step="4"><div class="fn-role">Agent 05</div><div class="fn-name">Report</div></div></div>
      <div class="flow-arr" data-arr="5"><svg viewBox="0 0 18 18" fill="none"><path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg></div>
      <div class="flow-node"><div class="fn-end" data-step="5"><div class="fn-role">Output</div><div class="fn-name">Pipeline</div><div class="fn-live"><span class="live-dot"></span>Autonomous</div></div></div>
    </div>
    <div class="stack-strip fu fd2">
      <span class="stack-chip">Claude API</span><span class="stack-chip">MCP</span><span class="stack-chip">Python</span><span class="stack-chip">Node.js</span><span class="stack-chip">React</span><span class="stack-chip">Next.js</span><span class="stack-chip">PostgreSQL</span><span class="stack-chip">HubSpot</span><span class="stack-chip">Salesforce</span><span class="stack-chip">Slack</span><span class="stack-chip">Notion</span>
    </div>
  </div>
</div>

<hr class="rule">

<!-- SERVICES -->
<section id="services" class="section">
  <div class="s-in">
    <div class="s-hd fu">
      <span class="eyebrow">What we build</span>
      <h2 data-split>Two disciplines.<br>One standard.</h2>
      <p>Whether you need an autonomous agent system or an AI-first software product, the approach is the same — AI at the center from day one, not retrofitted later.</p>
      <div class="quick-links">
        <a href="/services/ai-agent-development/">AI Agent Development →</a>
        <a href="/services/ai-workflow-automation/">AI Workflow Automation →</a>
        <a href="/services/saas-mvp-development/">SaaS MVP Development →</a>
        <a href="/services/" class="ql-all">All services →</a>
      </div>
    </div>
    <div class="svc-tabs fu" role="tablist" aria-label="Service categories">
      <button class="svc-tab active" id="tab-agents" role="tab" aria-selected="true" aria-controls="panel-agents" onclick="switchSvc(this,'agents')">AI Agent Systems</button>
      <button class="svc-tab" id="tab-software" role="tab" aria-selected="false" aria-controls="panel-software" onclick="switchSvc(this,'software')">AI-First Software</button>
    </div>

    <!-- AGENTS panel -->
    <div class="svc-panel active fu fd1" id="panel-agents" role="tabpanel" aria-labelledby="tab-agents">
      <div class="srv-grid">
        <div class="srv-card">
          <div class="srv-n">01 &nbsp;/&nbsp; Revenue</div>
          <h3>AI Revenue Engine</h3>
          <p>Autonomous outbound pipeline that researches prospects, writes personalised outreach, books meetings, and syncs every activity to your CRM — running continuously without SDR overhead.</p>
          <div class="srv-tags"><span class="srv-tag">Prospect research</span><span class="srv-tag">Personalised outreach</span><span class="srv-tag">CRM sync</span><span class="srv-tag">Meeting booking</span><span class="srv-tag">Pipeline reporting</span></div>
        </div>
        <div class="srv-card">
          <div class="srv-n">02 &nbsp;/&nbsp; Operations</div>
          <h3>AI Operations Agent</h3>
          <p>Workflow automation that eliminates manual coordination — approvals, document processing, internal reporting, knowledge retrieval, and cross-tool data sync. Fully autonomous, inside your stack.</p>
          <div class="srv-tags"><span class="srv-tag">Workflow automation</span><span class="srv-tag">Approvals</span><span class="srv-tag">Document processing</span><span class="srv-tag">Status reporting</span><span class="srv-tag">Data sync</span></div>
        </div>
        <div class="srv-card">
          <div class="srv-n">03 &nbsp;/&nbsp; Support</div>
          <h3>AI Customer Support Agent</h3>
          <p>Intelligent support agent that handles inbound queries, resolves common issues autonomously, escalates when needed, and logs every interaction — reducing ticket volume without sacrificing quality.</p>
          <div class="srv-tags"><span class="srv-tag">Inbound handling</span><span class="srv-tag">Auto-resolution</span><span class="srv-tag">Smart escalation</span><span class="srv-tag">CRM logging</span><span class="srv-tag">Sentiment tracking</span></div>
        </div>
        <div class="srv-card">
          <div class="srv-n">04 &nbsp;/&nbsp; Orchestration</div>
          <h3>Multi-Agent Systems</h3>
          <p>Production-grade architectures where multiple AI agents coordinate autonomously — each with defined roles, persistent memory, and tool access. Built for real users, real data, real scale.</p>
          <div class="srv-tags"><span class="srv-tag">Agent orchestration</span><span class="srv-tag">Memory systems</span><span class="srv-tag">Tool use</span><span class="srv-tag">Handoff protocols</span><span class="srv-tag">MCP integrations</span></div>
        </div>
      </div>
    </div>

    <!-- SOFTWARE panel -->
    <div class="svc-panel fu fd1" id="panel-software" role="tabpanel" aria-labelledby="tab-software">
      <div class="srv-grid">
        <div class="srv-card">
          <div class="srv-n">01 &nbsp;/&nbsp; SaaS Products</div>
          <h3>AI-First SaaS Platforms</h3>
          <p>SaaS products designed from the ground up with AI at the core — not a ChatGPT button added to a traditional app. Intelligent workflows, AI-powered features, and systems that learn from usage. Built on React, Next.js, and Node.</p>
          <div class="srv-tags"><span class="srv-tag">Next.js</span><span class="srv-tag">React</span><span class="srv-tag">Node.js</span><span class="srv-tag">AI workflows</span><span class="srv-tag">LLM integration</span></div>
        </div>
        <div class="srv-card">
          <div class="srv-n">02 &nbsp;/&nbsp; Internal Tools</div>
          <h3>AI-Powered Internal Tools</h3>
          <p>Custom internal platforms — dashboards, admin tools, ops software — built with AI embedded into every workflow. Document Q&amp;A, smart search, automated reporting, and AI decision support. No more manual data work.</p>
          <div class="srv-tags"><span class="srv-tag">Internal dashboards</span><span class="srv-tag">Smart search</span><span class="srv-tag">RAG systems</span><span class="srv-tag">Auto-reporting</span><span class="srv-tag">Document Q&amp;A</span></div>
        </div>
        <div class="srv-card">
          <div class="srv-n">03 &nbsp;/&nbsp; Vertical AI Apps</div>
          <h3>Vertical AI Applications</h3>
          <p>Industry-specific platforms built around a core AI capability — recruitment matching platforms, healthcare scheduling systems, logistics route optimization, real estate lead scoring. End-to-end from design to deployment.</p>
          <div class="srv-tags"><span class="srv-tag">Recruitment AI</span><span class="srv-tag">Healthcare</span><span class="srv-tag">Real estate</span><span class="srv-tag">Logistics</span><span class="srv-tag">Full-stack</span></div>
        </div>
        <div class="srv-card">
          <div class="srv-n">04 &nbsp;/&nbsp; AI Integration</div>
          <h3>AI Layer for Existing Products</h3>
          <p>Already have a product? We build the AI layer — adding Claude-powered features, intelligent automation, and agent capabilities to your existing codebase without a rewrite. Proper architecture, not quick hacks.</p>
          <div class="srv-tags"><span class="srv-tag">Claude API</span><span class="srv-tag">RAG</span><span class="srv-tag">Prompt engineering</span><span class="srv-tag">Evals</span><span class="srv-tag">Cost monitoring</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<hr class="rule">

<!-- ENGAGEMENT MODELS -->
<section id="engagements" class="section">
  <div class="s-in">
    <div class="s-hd fu">
      <span class="eyebrow">Engagement models</span>
      <h2 data-split>Choose the path<br>that matches your stage.</h2>
      <p>Some teams need a production agent system. Others need a full AI-first product. Others need the architecture first. We keep the entry point simple.</p>
    </div>
    <div class="eng-grid fu fd1">
      <div class="eng-card">
        <div class="eng-k">01 / Build</div>
        <h3>AI Agent System Build</h3>
        <p>For teams with a repeatable manual workflow in sales, support, operations, research, or back office work. We design and ship the agent system end to end.</p>
        <div class="eng-meta">
          <span>Typical timeline: 3-5 weeks</span>
          <span>Best for: workflow automation</span>
          <span>Output: deployed agent system</span>
        </div>
      </div>
      <div class="eng-card">
        <div class="eng-k">02 / Product</div>
        <h3>AI-First MVP Build</h3>
        <p>For founders and product teams building SaaS, internal tools, or vertical applications where AI is part of the core workflow from day one.</p>
        <div class="eng-meta">
          <span>Typical timeline: 4-8 weeks</span>
          <span>Best for: new software products</span>
          <span>Output: production-ready MVP</span>
        </div>
      </div>
      <div class="eng-card">
        <div class="eng-k">03 / Architecture</div>
        <h3>AI Automation Audit</h3>
        <p>For teams that know there is automation potential but need a clear map first. We identify the highest-ROI workflows and define the build plan.</p>
        <div class="eng-meta">
          <span>Typical timeline: 1 week</span>
          <span>Best for: unclear scope</span>
          <span>Output: architecture + proposal</span>
        </div>
      </div>
    </div>
  </div>
</section>

<hr class="rule">

<!-- AI-FIRST MANIFESTO -->
<div id="manifesto">
  <div class="mf-inner">
    <span class="eyebrow fu">Our philosophy</span>
    <blockquote class="fu fd1" data-split>"Most software companies add AI.<br>We <em>start</em> with AI and build everything else around it."</blockquote>
    <p class="fu fd2" style="font-size:15px;color:var(--t2);font-weight:300;line-height:1.75;max-width:600px;margin:0 auto;">The difference between AI-enhanced and AI-first isn't a feature. It's a design philosophy. When AI is the foundation, every workflow is faster, every system is more capable, and the software compounds in value over time.</p>
    <div class="mf-grid fu fd3">
      <div class="mf-card">
        <span class="mf-tag tag-old">Traditional approach</span>
        <h4>Build first, add AI later</h4>
        <p>Software is built around manual workflows, then an AI feature is bolted on. The AI is limited by the architecture it was never part of.</p>
      </div>
      <div class="mf-card">
        <span class="mf-tag tag-new">AI-first approach</span>
        <h4>Design the AI layer first</h4>
        <p>Every workflow is designed around what AI should handle. The software is built to support that — resulting in deeper automation and systems that improve with use.</p>
      </div>
      <div class="mf-card">
        <span class="mf-tag tag-new">The outcome</span>
        <h4>Software that gets smarter</h4>
        <p>AI-first systems accumulate intelligence over time. The more they're used, the better they get. Traditional software doesn't do that.</p>
      </div>
    </div>
  </div>
</div>

<hr class="rule">

<!-- WHY US -->
<section id="why" class="section">
  <div class="s-in">
    <div class="s-hd fu">
      <span class="eyebrow">Why Devsphinx</span>
      <h2 data-split>Built for production.<br>Not proof of concept.</h2>
      <p>The gap between an AI demo and a system that creates real business value — is architecture, scope discipline, and what happens after launch.</p>
    </div>
    <div class="why-grid fu fd1">
      <div class="why-card">
        <div class="why-ic"><svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
        <h3>Outcome-scoped delivery</h3>
        <p>Every engagement is scoped to a business outcome — hours saved, pipeline generated, tickets deflected. We measure success in results, not features shipped.</p>
      </div>
      <div class="why-card">
        <div class="why-ic"><svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
        <h3>Fixed scope, fixed price</h3>
        <p>After the discovery call you receive a fixed-scope proposal with a defined deliverable, timeline, and price. No hourly billing. No scope creep. No surprises.</p>
      </div>
      <div class="why-card">
        <div class="why-ic"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
        <h3>3–5 week delivery</h3>
        <p>We ship in weeks, not quarters. AI-first development using Claude agents in our own workflow compresses timelines without cutting corners on quality.</p>
      </div>
      <div class="why-card">
        <div class="why-ic"><svg viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg></div>
        <h3>Claude-native from day one</h3>
        <p>Whether it's an agent system or a SaaS product, every architecture is designed around Claude's capabilities — not adapted to fit them afterward.</p>
      </div>
      <div class="why-card">
        <div class="why-ic"><svg viewBox="0 0 24 24"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg></div>
        <h3>Compounds after launch</h3>
        <p>AI-first systems get better with data. Our retainer clients see the biggest performance and capability gains at 30, 60, and 90 days — long after the initial build.</p>
      </div>
      <div class="why-card">
        <div class="why-ic"><svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></div>
        <h3>Works with your team</h3>
        <p>We work alongside your existing stack and your existing team. No rip-and-replace. No learning curve on tools you already use. We fit in, not over.</p>
      </div>
    </div>
  </div>
</section>

<hr class="rule">

<!-- PROCESS -->
<section id="process" class="section">
  <div class="s-in">
    <div class="s-hd fu">
      <span class="eyebrow">How it works</span>
      <h2 data-split>Problem to shipped<br>system in 5 steps.</h2>
      <p>A clear, accountable process with weekly demos and natural check-in points — same flow whether we're building an agent system or a full product.</p>
    </div>
    <div class="proc-list fu fd1">
      <div class="proc-row">
        <div class="proc-n">01</div>
        <div class="proc-body">
          <h3>Discovery call</h3>
          <p>A free 30-minute session. We map the workflow you want to automate, or the product you want to build. We identify what AI should own, what the integrations are, and what success looks like. Free, no obligation.</p>
        </div>
        <div class="p-badge pb-build">Free · 30 min</div>
      </div>
      <div class="proc-row">
        <div class="proc-n">02</div>
        <div class="proc-body">
          <h3>Scoped proposal</h3>
