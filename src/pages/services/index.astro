---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/case-study.css';
import '../../styles/service.css';

const title = "Services — AI Agents, SaaS MVPs, Automation & Custom Software — Devsphinx";
const description = "Every service Devsphinx offers, from AI agent systems to Ruby on Rails and healthcare software — fixed price, founder-led.";

const aiAutomation = [
  { title: 'AI Agent Development', desc: 'Autonomous multi-agent systems for sales, support, and operations, built on Claude and MCP.', price: 'From $8,000', href: '/services/ai-agent-development/' },
  { title: 'AI Workflow Automation', desc: 'Automation that reasons and acts — not just moves data between apps.', price: 'From $8,000', href: '/services/ai-workflow-automation/' },
  { title: 'CRM Automation', desc: 'AI agents layered onto HubSpot, Salesforce, and custom CRMs.', price: 'From $6,000', href: '/services/crm-automation/' },
];

const softwareDev = [
  { title: 'SaaS MVP Development', desc: 'AI-first SaaS MVPs built on Next.js and Node.js, shipped in 4–8 weeks.', price: 'From $12,000', href: '/services/saas-mvp-development/' },
  { title: 'Custom Software Development', desc: 'Bespoke software with AI built into the architecture from the start.', price: 'From $10,000', href: '/services/custom-software-development/' },
  { title: 'Ruby on Rails Development', desc: 'New Rails builds and AI layers added to existing Rails codebases.', price: 'From $6,000', href: '/services/ruby-on-rails-development/' },
  { title: 'Healthcare Software Development', desc: 'HIPAA-aware scheduling, intake, and clinical workflow software.', price: 'From $15,000', href: '/services/healthcare-software-development/' },
];

const allServices = [...aiAutomation, ...softwareDev];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ItemList",
      "itemListElement": allServices.map((s, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": s.title,
        "url": `https://www.devshinx.dev${s.href}`
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.devshinx.dev/" },
        { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://www.devshinx.dev/services/" }
      ]
    }
  ]
};
---

<BaseLayout title={title} description={description}>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<nav>
  <a href="/" class="nav-logo">Dev<em>sphinx</em></a>
  <a href="/" class="nav-back">← Back to Devsphinx</a>
</nav>

<section id="hero">
  <div class="hero-inner">
    <div class="hero-top fu">
      <div>
        <div class="hero-eyebrow"><span class="eyebrow eyebrow-ac">Services</span></div>
        <h1 class="hero-h1">Every way we help you build <em>with AI at the core.</em></h1>
        <p class="hero-desc">Whether you need an autonomous agent system or a full software product, the approach is the same — AI at the center from day one, fixed price, founder-led.</p>
        <div class="btns"><a href="/#booking" class="btn btn-ac">Not sure which fits? Book a discovery call →</a></div>
      </div>
      <div class="hero-stats fu fd2">
        <div class="hs-cell"><div class="hs-n">7</div><div class="hs-l">Services, each fixed price</div></div>
        <div class="hs-cell"><div class="hs-n">0<em>%</em></div><div class="hs-l">Hourly billing</div></div>
        <div class="hs-cell"><div class="hs-n">1</div><div class="hs-l">Founder, every engagement</div></div>
      </div>
    </div>
  </div>
</section>

<hr class="rule">

<div class="cs fu">
  <div class="svc-hub-group-label">AI &amp; Automation</div>
  <div class="svc-hub-grid cols-3">
    {aiAutomation.map((s) => (
      <a class="svc-hub-card" href={s.href}>
        <h3>{s.title}</h3>
        <p>{s.desc}</p>
        <div class="svc-hub-foot">
          <span class="svc-hub-price">{s.price}</span>
          <span class="svc-hub-link">Learn more →</span>
        </div>
      </a>
    ))}
  </div>

  <div class="svc-hub-group-label">Software Development</div>
  <div class="svc-hub-grid">
    {softwareDev.map((s) => (
      <a class="svc-hub-card" href={s.href}>
        <h3>{s.title}</h3>
        <p>{s.desc}</p>
        <div class="svc-hub-foot">
          <span class="svc-hub-price">{s.price}</span>
          <span class="svc-hub-link">Learn more →</span>
        </div>
      </a>
    ))}
  </div>
</div>

<hr class="rule">

<div class="cta-section">
  <div class="cta-inner fu">
    <h2>Not sure which service fits your problem?</h2>
    <div class="btns">
      <a href="/#booking" class="btn btn-ac">Book a discovery call →</a>
      <a href="/" class="btn btn-ghost">Back to Devsphinx</a>
    </div>
  </div>
</div>

<footer>
  <a href="/" class="f-logo">Dev<em>sphinx</em></a>
  <span class="f-copy">© 2026 Devsphinx · AI-First Software Studio</span>
</footer>

<script is:inline>
const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('vis');}),{threshold:.07});
document.querySelectorAll('.fu').forEach(el=>obs.observe(el));
</script>
</BaseLayout>
