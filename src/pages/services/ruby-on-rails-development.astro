---
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/case-study.css';
import '../../styles/service.css';

const title = "Ruby on Rails Development Agency — Devsphinx";
const description = "New Rails builds and AI layers added to existing Rails codebases — without a rewrite.";

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Ruby on Rails Development",
      "provider": { "@id": "https://www.devshinx.dev/#org" },
      "serviceType": "Ruby on Rails development",
      "areaServed": "Worldwide",
      "description": description,
      "offers": {
        "@type": "Offer",
        "priceCurrency": "USD",
        "price": "6000",
        "priceSpecification": { "@type": "PriceSpecification", "minPrice": "6000", "priceCurrency": "USD" }
      },
      "url": "https://www.devshinx.dev/services/ruby-on-rails-development/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "Do you work with legacy Rails versions?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — a codebase review during discovery tells us what's involved before we scope any upgrade or new-feature work." } },
        { "@type": "Question", "name": "Can you add AI without touching our core models?", "acceptedAnswer": { "@type": "Answer", "text": "In most cases yes — AI capability is usually added as a new layer (a service object, a background job, a new controller) rather than rewriting core models." } },
        { "@type": "Question", "name": "Do you offer ongoing maintenance?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, on a monthly retainer starting at $2,500/month, with response expectations agreed upfront." } },
        { "@type": "Question", "name": "Ruby on Rails or Next.js — which should we choose?", "acceptedAnswer": { "@type": "Answer", "text": "If you already have a Rails codebase, extending it is almost always cheaper and faster than a rewrite. For a brand-new product with no existing codebase, we'll recommend based on your team's familiarity and the product's needs." } },
        { "@type": "Question", "name": "What happens if you're at capacity, or I need support after launch?", "acceptedAnswer": { "@type": "Answer", "text": "We only take on a small number of builds at a time, so if we can't meet your timeline, we'll tell you honestly on the discovery call and point you to someone we trust rather than overcommit. Ongoing support runs on a monthly retainer with response expectations agreed upfront." } }
      ]
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.devshinx.dev/" },
        { "@type": "ListItem", "position": 2, "name": "Ruby on Rails Development", "item": "https://www.devshinx.dev/services/ruby-on-rails-development/" }
      ]
    }
  ]
};
---

<BaseLayout title={title} description={description}>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
<nav>
  <a href="/" class="nav-logo">Dev<em>sphinx</em></a>
  <a href="/" class="nav-back">← Back to Devsphinx</a>
</nav>

<section id="hero">
  <div class="hero-inner">
    <div class="hero-top fu">
      <div>
        <div class="hero-eyebrow"><span class="eyebrow eyebrow-ac">Services · Ruby on Rails Development</span></div>
        <h1 class="hero-h1">Rails development, <em>with an AI layer</em> if you want one.</h1>
        <p class="hero-desc">Whether you're starting a new Rails application or your existing one needs an AI capability added without a rewrite, we work inside the framework you already trust.</p>
        <div class="btns"><a href="/#booking" class="btn btn-ac">Book a discovery call →</a></div>
      </div>
      <div class="hero-stats fu fd2">
        <div class="hs-cell"><div class="hs-n">$6k<em>+</em></div><div class="hs-l">AI-layer additions, starting price</div></div>
        <div class="hs-cell"><div class="hs-n">$12k<em>+</em></div><div class="hs-l">New builds, starting price</div></div>
        <div class="hs-cell"><div class="hs-n">0<em>%</em></div><div class="hs-l">Hourly billing</div></div>
      </div>
    </div>
  </div>
</section>

<hr class="rule">

<div class="cs fu">
  <div class="cs-eye">The problem</div>
  <h2 class="cs-h2">Adding AI shouldn't mean<br>rewriting a business that already works.</h2>
  <p class="cs-p">Rails applications run real businesses with real users and real data — but adding modern AI capability often gets treated as a reason to rewrite in a newer stack. That's an expensive, risky detour most teams can't afford, and most of the time, it isn't necessary.</p>
  <div class="prob-grid fu fd1">
    <div class="prob-card prob-old">
      <div class="prob-label">The rewrite instinct</div>
      <h3>Treat AI as a reason to start over.</h3>
      <p>A perfectly working Rails app gets shelved because "AI needs a modern stack" — months of risk for a capability that didn't require it.</p>
      <ul class="prob-list">
        <li>Months of migration risk on a system that already works</li>
        <li>Team has to relearn a new stack mid-project</li>
        <li>Existing data and integrations have to be rebuilt</li>
      </ul>
    </div>
    <div class="prob-card prob-new">
      <div class="prob-label">Adding AI to Rails</div>
      <h3>Extend what's already working.</h3>
      <p>AI capability layered into the existing app — new service objects, background jobs, an agent layer — without touching what already works.</p>
      <ul class="prob-list">
        <li>Existing models, data, and integrations stay intact</li>
        <li>Your team keeps working in the framework they know</li>
        <li>Ships in weeks, not months</li>
      </ul>
    </div>
  </div>
</div>

<hr class="rule">

<div class="cs fu">
  <div class="cs-eye">What we build</div>
  <h2 class="cs-h2">New Rails applications,<br>or AI added to your existing one.</h2>
  <p class="cs-p">We add AI capability — smart search, document processing, an agent layer — directly into your existing Rails app, or build a new one the same way from day one.</p>
  <div class="con-card" style="max-width:680px;margin-top:24px;">
    <div class="con-lbl">Deliverables</div>
    <ul class="con-list">
      <li>Rails application build, or an AI-layer integration into an existing app</li>
      <li>Test coverage for anything touched</li>
      <li>Deployment pipeline setup or handover</li>
      <li>Documentation for your in-house team</li>
    </ul>
  </div>
  <div class="stack-chips fu fd1">
    <span class="s-chip pri">Ruby on Rails</span><span class="s-chip pri">Claude API</span><span class="s-chip pri">MCP</span><span class="s-chip">Sidekiq</span><span class="s-chip">PostgreSQL</span><span class="s-chip">pgvector</span>
  </div>
</div>

<hr class="rule">

<div class="cs fu">
  <div class="cs-eye">Process &amp; pricing</div>
  <h2 class="cs-h2">Codebase review first,<br>then a fixed number.</h2>
  <p class="cs-p">For existing Rails apps, a short codebase review during discovery is what makes the fixed price accurate.</p>
  <div class="step-list fu fd1">
    <div class="step-row"><span class="step-n">01</span><span class="step-txt"><strong>Discovery call</strong> — free, 30 minutes. We map what you're adding and what already exists.</span></div>
    <div class="step-row"><span class="step-n">02</span><span class="step-txt"><strong>Codebase review</strong> — for existing projects, before we quote a number.</span></div>
    <div class="step-row"><span class="step-n">03</span><span class="step-txt"><strong>Scoped proposal</strong> — fixed price and timeline, within 5 business days.</span></div>
    <div class="step-row"><span class="step-n">04</span><span class="step-txt"><strong>Build, with weekly demos</strong> — on real data, in a staging environment you can access.</span></div>
    <div class="step-row"><span class="step-n">05</span><span class="step-txt"><strong>Deploy + hypercare</strong> — 2 weeks of tuning after launch, optional retainer after that.</span></div>
  </div>
  <div class="price-grid fu fd2">
    <div class="price-cell"><div class="price-n">$6,000</div><div class="price-l">AI-layer addition, starting price</div></div>
    <div class="price-cell"><div class="price-n">$12,000</div><div class="price-l">New Rails build, starting price</div></div>
    <div class="price-cell"><div class="price-n">$2,500/mo</div><div class="price-l">Optional retainer</div></div>
  </div>
</div>

<hr class="rule">

<div class="cs fu">
  <div class="cs-eye">FAQs</div>
  <h2 class="cs-h2">Questions before<br>the call.</h2>
  <div class="faq-wrap fu fd1">
    <div class="faq-row">
      <button class="faq-btn" aria-expanded="false" aria-controls="ror1" onclick="toggleFaq(this)">Do you work with legacy Rails versions?<span class="faq-ic">+</span></button>
      <div class="faq-body" id="ror1"><div class="faq-inner">Yes — a codebase review during discovery tells us what's involved before we scope any upgrade or new-feature work.</div></div>
    </div>
    <div class="faq-row">
      <button class="faq-btn" aria-expanded="false" aria-controls="ror2" onclick="toggleFaq(this)">Can you add AI without touching our core models?<span class="faq-ic">+</span></button>
      <div class="faq-body" id="ror2"><div class="faq-inner">In most cases yes — AI capability is usually added as a new layer (a service object, a background job, a new controller) rather than rewriting core models.</div></div>
    </div>
    <div class="faq-row">
      <button class="faq-btn" aria-expanded="false" aria-controls="ror3" onclick="toggleFaq(this)">Do you offer ongoing maintenance?<span class="faq-ic">+</span></button>
      <div class="faq-body" id="ror3"><div class="faq-inner">Yes, on a monthly retainer starting at $2,500/month, with response expectations agreed upfront.</div></div>
    </div>
    <div class="faq-row">
      <button class="faq-btn" aria-expanded="false" aria-controls="ror4" onclick="toggleFaq(this)">Ruby on Rails or Next.js — which should we choose?<span class="faq-ic">+</span></button>
      <div class="faq-body" id="ror4"><div class="faq-inner">If you already have a Rails codebase, extending it is almost always cheaper and faster than a rewrite. For a brand-new product with no existing codebase, we'll recommend based on your team's familiarity and the product's needs.</div></div>
    </div>
    <div class="faq-row">
      <button class="faq-btn" aria-expanded="false" aria-controls="ror5" onclick="toggleFaq(this)">What happens if you're at capacity, or I need support after launch?<span class="faq-ic">+</span></button>
      <div class="faq-body" id="ror5"><div class="faq-inner">We only take on a small number of builds at a time, so if we can't meet your timeline, we'll tell you honestly on the discovery call and point you to someone we trust rather than overcommit. Ongoing support runs on a monthly retainer with response expectations agreed upfront.</div></div>
    </div>
  </div>
  <div class="related-links fu fd2">
    <a href="/services/custom-software-development/">Custom Software Development →</a>
    <a href="/services/ai-workflow-automation/">AI Workflow Automation →</a>
    <a href="/#founder">About Devsphinx →</a>
  </div>
</div>

<hr class="rule">

<div class="cta-section">
  <div class="cta-inner fu">
    <h2>Running Rails and want an AI layer added the right way?</h2>
    <div class="btns">
      <a href="/#booking" class="btn btn-ac">Book a discovery call →</a>
      <a href="/" class="btn btn-ghost">Back to Devsphinx</a>
    </div>
  </div>
</div>

<footer>
  <a href="/" class="f-logo">Dev<em>sphinx</em></a>
  <span class="f-copy">© 2026 Devsphinx · AI-First Software Studio</span>
</footer>

<script is:inline>
function toggleFaq(btn){const row=btn.closest('.faq-row'),was=row.classList.contains('open');document.querySelectorAll('.faq-row.open').forEach(r=>{r.classList.remove('open');const b=r.querySelector('.faq-btn');if(b)b.setAttribute('aria-expanded','false');});if(!was){row.classList.add('open');btn.setAttribute('aria-expanded','true');}else{btn.setAttribute('aria-expanded','false');}}
const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('vis');}),{threshold:.07});
document.querySelectorAll('.fu').forEach(el=>obs.observe(el));
</script>
</BaseLayout>
