---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/case-study.css';
import '../../styles/blog.css';

const title = "Resources — AI Agents, SaaS, and Automation — Devsphinx";
const description = "Plain-English guides on AI agents, SaaS MVPs, and automation for founders and operators.";

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featured = posts[0];
const rest = posts.slice(1);

// Topics queued in the 90-day content plan, not yet written.
const upcoming = [
  { clusterLabel: 'SaaS MVP', title: 'SaaS MVP Development Cost Breakdown (2026)' },
  { clusterLabel: 'Automation for SMEs', title: 'Automating Sales Outreach With AI Agents, Step by Step' },
  { clusterLabel: 'Healthcare', title: "HIPAA-Compliant AI: What's Actually Allowed" },
  { clusterLabel: 'Founder-Led', title: 'Why We Build Software That Thinks' },
];
---

<BaseLayout title={title} description={description}>
<nav>
  <a href="/" class="nav-logo">Dev<em>sphinx</em></a>
  <a href="/" class="nav-back">← Back to Devsphinx</a>
</nav>

<div class="blog-hero fu">
  <h1>Resources for people building with AI.</h1>
  <p>Plain-English guides on AI agents, SaaS MVPs, and automation — for <strong>founders and operators</strong>, not just engineers.</p>
</div>

<div class="blog-wrap">
  {!featured ? (
    <p class="post-empty">First posts publishing soon.</p>
  ) : (
    <>
      <a class="post-featured fu fd1" href={`/blog/${featured.id}/`}>
        <span class="article-tag">{featured.data.clusterLabel}</span>
        <h2>{featured.data.title}</h2>
        <p>{featured.data.description}</p>
        <div class="post-featured-foot">
          <span class="article-date">{featured.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          <span class="pf-sep"></span>
          <span class="pf-read">Read Guide →</span>
        </div>
      </a>

      {rest.length > 0 && (
        <div class="post-grid fu fd2" style="margin-bottom:20px;">
          {rest.map((post) => (
            <a class="post-teaser" href={`/blog/${post.id}/`} style="display:block;">
              <span class="article-tag">{post.data.clusterLabel}</span>
              <h3 style="color:var(--t);">{post.data.title}</h3>
              <span class="article-date">{post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </a>
          ))}
        </div>
      )}
    </>
  )}

  <div class="post-upcoming-label fu fd2">Coming up next</div>
  <div class="post-grid fu fd3">
    {upcoming.map((item) => (
      <div class="post-teaser">
        <span class="article-tag">{item.clusterLabel}</span>
        <h3>{item.title}</h3>
        <span class="post-soon">Coming soon</span>
      </div>
    ))}
  </div>
</div>

<footer>
  <a href="/" class="f-logo">Dev<em>sphinx</em></a>
  <span class="f-copy">© 2026 Devsphinx · AI-First Software Studio</span>
</footer>

<script is:inline>
const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('vis');}),{threshold:.05});
document.querySelectorAll('.fu').forEach(el=>obs.observe(el));
</script>
</BaseLayout>
