---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/case-study.css';
import '../../styles/blog.css';

const title = "Resources — AI Agents, SaaS, and Automation — Devsphinx";
const description = "Plain-English guides on AI agents, SaaS MVPs, and automation for founders and operators.";

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featured = posts[0];
const rest = posts.slice(1);

const AUTHOR_INITIALS = 'SN';

// Next posts in the 90-day content plan, in order, not yet written.
const upcoming = [];
---

<BaseLayout title={title} description={description}>
<nav>
  <a href="/" class="nav-logo">Dev<em>sphinx</em></a>
  <a href="/" class="nav-back">← Back to Devsphinx</a>
</nav>

<main>

<div class="blog-hero fu">
  <h1>Resources for people building with AI.</h1>
  <p>Plain-English guides on AI agents, SaaS MVPs, and automation — for <strong>founders and operators</strong>, not just engineers.</p>
</div>

<div class="blog-wrap">
  {!featured ? (
    <p class="post-empty">First posts publishing soon.</p>
  ) : (
    <div class="bento-grid fu fd1">
      <a class="bento-featured" href={`/blog/${featured.id}/`}>
        <span class="bento-tag-solid">Featured Guide</span>
        <h2>{featured.data.title}</h2>
        <p>{featured.data.description}</p>
        <div class="bento-featured-foot">
          <span class="bento-avatar">{AUTHOR_INITIALS}</span>
          <span class="bento-meta-txt">{featured.data.readingTime} · {featured.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</span>
        </div>
        <span class="bento-arrow" aria-hidden="true"><svg viewBox="0 0 24 24"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      </a>

      {rest.map((post) => (
        <a class="bento-card" href={`/blog/${post.id}/`}>
          <span class="bento-icon" aria-hidden="true"><svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span>
          <h3 style="color:var(--t);">{post.data.title}</h3>
          <span class="bento-soon" style="color:var(--ac);">{post.data.readingTime}</span>
        </a>
      ))}

      {upcoming.map((item) => (
        <div class="bento-card">
          <span class="bento-icon" aria-hidden="true" set:html={`<svg viewBox="0 0 24 24">${item.icon}</svg>`} />
          <h3>{item.title}</h3>
          <span class="bento-soon">Coming soon</span>
        </div>
      ))}
    </div>
  )}
</div>

</main>

<footer>
  <a href="/" class="f-logo">Dev<em>sphinx</em></a>
  <span class="f-copy">© 2026 Devsphinx · AI-First Software Studio</span>
</footer>

<script is:inline>
const obs=new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('vis');}),{threshold:.05});
document.querySelectorAll('.fu').forEach(el=>obs.observe(el));
</script>
</BaseLayout>
