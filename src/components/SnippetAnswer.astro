<div class="snippet-answer">
  <span class="sa-label">Quick answer</span>
  <p><slot /></p>
</div>

<style>
.snippet-answer{background:var(--bg2);border:1px solid var(--b);border-left:3px solid var(--ac);border-radius:10px;padding:20px 24px;margin:28px 0;}
.sa-label{font-family:var(--M);font-size:10px;letter-spacing:.12em;text-transform:uppercase;color:var(--ac);display:block;margin-bottom:8px;}
.snippet-answer p{font-size:15px;color:var(--t);font-weight:400;line-height:1.75;margin:0;}
</style>
